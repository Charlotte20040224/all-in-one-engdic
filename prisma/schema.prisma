generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  nickname      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  words        Word[]
  sentences    Sentence[]
  activityLogs ActivityLog[]
  settings     UserSettings?
  posts        Post[]
  likes        Like[]
  comments     Comment[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Word {
  id          String    @id @default(uuid())
  userId      String
  english     String
  ipa         String?
  ipaUS       String?
  ipaGB       String?
  meaning     String?
  pos         String?
  examples    Json?
  collocations Json?
  synonyms    Json?
  antonyms    Json?
  variants    Json?
  note        String?
  srsLevel    Int       @default(0)
  nextReview  DateTime  @default(now())
  lastReview  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("words")
}

model Sentence {
  id          String   @id @default(cuid())
  userId      String
  english     String
  ipa         String
  ipaUS       String?
  ipaGB       String?
  zh          String
  grammar     String?
  grammarPattern String?
  vocabulary  Json?
  nextReview  DateTime @default(now())
  interval    Int      @default(1)
  easeFactor  Float    @default(2.5)
  repetitions Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sentences")
}

model ActivityLog {
  id       String   @id @default(uuid())
  userId   String
  date     DateTime @db.Date
  reviewed Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("activity_log")
}

model UserSettings {
  userId    String @id
  dailyGoal Int    @default(10)
  ttsSpeed  Float  @default(0.7)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  type      String[]
  rating    Int?
  message   String
  createdAt DateTime @default(now())

  @@map("feedback")
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String[]
  content   String
  isPublic  Boolean   @default(true)
  likes     Like[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([isPublic, createdAt])
  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([postId, createdAt])
  @@map("comments")
}
